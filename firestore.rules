rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // หมายเหตุ: Firestore จะปฏิเสธ query (list) ที่ "ไม่กรอง" ด้วย where() ตรงกับเงื่อนไขใน rule
    // ทันที ถ้า rule นั้นอ้างอิง resource.data — แต่ถ้า query มี where() ตรงกับฟิลด์ที่ rule เช็ค
    // (เช่น where('team','==',myTeam)) จะอนุญาตตามปกติ (ทดสอบยืนยันแล้ว)
    // ผู้ดูแลระบบ (isAdmin) ไม่ผูกกับ resource.data เลย จึง query แบบไม่กรองได้เสมอ
    function isSignedIn() { return request.auth != null; }
    function isCoach() { return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous'; }
    function myCoachDoc() {
      return get(/databases/$(database)/documents/coaches/$(request.auth.uid)).data;
    }
    function myRole() { return myCoachDoc().role; }
    function isApproved() { return isCoach() && myCoachDoc().status == 'approved'; }
    function isAdmin() { return isCoach() && myRole() == 'admin'; }
    // โค้ช = จัดการข้อมูล (เขียนได้) / ผู้บริหารทีม = ดูอย่างเดียว (อ่านได้ เขียนไม่ได้)
    function canManageTeam() { return isApproved() && myRole() == 'coach'; }
    function canViewTeam() { return isApproved() && (myRole() == 'coach' || myRole() == 'executive'); }
    function myTeam() { return myCoachDoc().team; }
    function ownsTeam() { return 'team' in resource.data && resource.data.team == myTeam(); }

    match /coaches/{coachId} {
      allow read: if isSignedIn();
      // ผู้ลงทะเบียนใหม่สร้างโปรไฟล์ของตัวเองได้ (สถานะ pending) เลือกบทบาทได้แค่ coach/executive
      // (กำหนด admin หรือ team เองไม่ได้) ผู้ดูแลระบบเป็นผู้กำหนด team ให้ตอนอนุมัติ (หรือเปลี่ยนภายหลังได้)
      // โค้ชต้องระบุ ageGroup (รุ่นอายุที่รับผิดชอบ) ตั้งแต่ตอนลงทะเบียน — ผู้บริหารทีมไม่ต้องระบุ
      // (ตัดการใช้เบอร์โทรศัพท์ออกจากระบบเข้าสู่ระบบ/ลงทะเบียนแล้ว)
      allow create: if isSignedIn()
                     && request.auth.uid == coachId
                     && request.resource.data.keys().hasOnly(['name', 'email', 'role', 'status', 'createdAt', 'ageGroup'])
                     && request.resource.data.email == request.auth.token.email
                     && request.resource.data.role in ['coach', 'executive']
                     && request.resource.data.status == 'pending'
                     && (request.resource.data.role != 'coach'
                         || ('ageGroup' in request.resource.data && request.resource.data.ageGroup is string && request.resource.data.ageGroup.size() > 0));
      // ผู้ดูแลระบบเท่านั้นที่อนุมัติ/กำหนด team หรือแก้ไข/ลบบัญชีได้
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /players/{id} {
      allow read: if isAdmin() || (canViewTeam() && ownsTeam());
      allow create: if isAdmin() || (canManageTeam() && request.resource.data.team == myTeam());
      allow update: if isAdmin() || (canManageTeam() && ownsTeam() && request.resource.data.team == myTeam());
      allow delete: if isAdmin() || (canManageTeam() && ownsTeam());
    }

    match /sessions/{id} {
      allow read: if isAdmin() || (canViewTeam() && ownsTeam());
      allow create: if isAdmin() || (canManageTeam() && request.resource.data.team == myTeam());
      allow update: if isAdmin() || (canManageTeam() && ownsTeam());
      allow delete: if false;
    }

    match /attendance/{id} {
      allow read: if isAdmin() || (canViewTeam() && ownsTeam());
      allow create: if isAdmin() || (canManageTeam() && request.resource.data.team == myTeam());
      allow update: if isAdmin() || (canManageTeam() && ownsTeam() && request.resource.data.team == myTeam());
      allow delete: if false;
    }

    // รายงานการฝึกซ้อม (รายชื่อนักกีฬาที่ไม่ได้เข้าซ้อม + พิกัด GPS ตอนส่ง)
    // โค้ชสร้าง/แก้ไขได้เฉพาะรายงานของทีมตัวเอง ผู้บริหารทีมดูได้อย่างเดียว (canViewTeam)
    match /trainingReports/{id} {
      allow read: if isAdmin() || (canViewTeam() && ownsTeam());
      allow create: if isAdmin() || (canManageTeam() && request.resource.data.team == myTeam());
      allow update: if isAdmin() || (canManageTeam() && ownsTeam() && request.resource.data.team == myTeam());
      allow delete: if isAdmin();
    }

    // รายงานผลการแข่งขัน — โค้ชจัดการได้เฉพาะรายการของทีมตัวเอง ผู้บริหารทีมดูได้อย่างเดียว
    match /matchReports/{id} {
      allow read: if isAdmin() || (canViewTeam() && ownsTeam());
      allow create: if isAdmin() || (canManageTeam() && request.resource.data.team == myTeam());
      allow update: if isAdmin() || (canManageTeam() && ownsTeam() && request.resource.data.team == myTeam());
      allow delete: if isAdmin() || (canManageTeam() && ownsTeam());
    }

    // รายงานอาการบาดเจ็บ — โค้ชจัดการได้เฉพาะรายการของทีมตัวเอง ผู้บริหารทีมดูได้อย่างเดียว
    match /injuryReports/{id} {
      allow read: if isAdmin() || (canViewTeam() && ownsTeam());
      allow create: if isAdmin() || (canManageTeam() && request.resource.data.team == myTeam());
      allow update: if isAdmin() || (canManageTeam() && ownsTeam() && request.resource.data.team == myTeam());
      allow delete: if isAdmin() || (canManageTeam() && ownsTeam());
    }

    // แผนการฝึกซ้อมรายวัน — โค้ชจัดการได้เฉพาะแผนของทีมตัวเอง ผู้บริหารทีมดูได้อย่างเดียว
    match /trainingPlans/{id} {
      allow read: if isAdmin() || (canViewTeam() && ownsTeam());
      allow create: if isAdmin() || (canManageTeam() && request.resource.data.team == myTeam());
      allow update: if isAdmin() || (canManageTeam() && ownsTeam() && request.resource.data.team == myTeam());
      allow delete: if isAdmin() || (canManageTeam() && ownsTeam());
    }

    // ข้อความที่ผู้ดูแลระบบส่งถึงทีม (เช่น แจ้งนักกีฬาที่มีพัฒนาการดี หรือแจ้งปัญหาของโค้ช) — ส่งได้เฉพาะ
    // ผู้ดูแลระบบเท่านั้น โค้ช/ผู้บริหารทีมของทีมนั้นอ่านได้และแก้ไขได้แค่ทำเครื่องหมายว่าอ่านแล้ว (read: true)
    match /executiveNotes/{id} {
      allow read: if isAdmin() || (canViewTeam() && ownsTeam());
      allow create: if isAdmin();
      allow update: if isAdmin() || (canViewTeam() && ownsTeam());
      allow delete: if isAdmin();
    }
  }
}
