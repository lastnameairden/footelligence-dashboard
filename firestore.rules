rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // หมายเหตุ: Firestore จะปฏิเสธ query (list) ที่ "ไม่กรอง" ด้วย where() ตรงกับเงื่อนไขใน rule
    // ทันที ถ้า rule นั้นอ้างอิง resource.data — แต่ถ้า query มี where() ตรงกับฟิลด์ที่ rule เช็ค
    // (เช่น where('team','==',myTeam)) จะอนุญาตตามปกติ (ทดสอบยืนยันแล้ว)
    // ผู้ดูแลระบบ (isAdmin) ไม่ผูกกับ resource.data เลย จึง query แบบไม่กรองได้เสมอ
    function isSignedIn() { return request.auth != null; }
    function isCoach() { return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous'; }
    function myCoachDoc() {
      return get(/databases/$(database)/documents/coaches/$(request.auth.uid)).data;
    }
    function isAdmin() { return isCoach() && myCoachDoc().role == 'admin'; }
    function isApprovedCoach() { return isCoach() && myCoachDoc().status == 'approved'; }
    function myTeam() { return myCoachDoc().team; }
    function ownsTeam() { return 'team' in resource.data && resource.data.team == myTeam(); }

    match /coaches/{coachId} {
      allow read: if isSignedIn();
      // โค้ชใหม่สร้างโปรไฟล์ของตัวเองได้ (สถานะ pending) แต่กำหนด team/role เองไม่ได้
      // ผู้ดูแลระบบเป็นผู้กำหนด team ให้ตอนอนุมัติ (หรือเปลี่ยนภายหลังได้)
      allow create: if isSignedIn()
                     && request.auth.uid == coachId
                     && request.resource.data.keys().hasOnly(['name', 'email', 'status', 'createdAt'])
                     && request.resource.data.email == request.auth.token.email
                     && request.resource.data.status == 'pending';
      // ผู้ดูแลระบบเท่านั้นที่อนุมัติ/กำหนด team หรือแก้ไข/ลบบัญชีโค้ชได้
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /players/{id} {
      allow read: if isAdmin() || (isApprovedCoach() && ownsTeam());
      allow create: if isAdmin() || (isApprovedCoach() && request.resource.data.team == myTeam());
      allow update: if isAdmin() || (isApprovedCoach() && ownsTeam() && request.resource.data.team == myTeam());
      allow delete: if isAdmin() || (isApprovedCoach() && ownsTeam());
    }

    match /sessions/{id} {
      allow read: if isAdmin() || (isApprovedCoach() && ownsTeam());
      allow create: if isAdmin() || (isApprovedCoach() && request.resource.data.team == myTeam());
      allow update: if isAdmin() || (isApprovedCoach() && ownsTeam());
      allow delete: if false;
    }

    match /attendance/{id} {
      allow read: if isAdmin() || (isApprovedCoach() && ownsTeam());
      allow write: if isAdmin() || (isApprovedCoach() && request.resource.data.team == myTeam());
    }
  }
}
